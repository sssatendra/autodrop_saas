RAZORPAY_WEBHOOK_SECRET=xxxx
RAZORPAY_STARTER_PLAN_ID=plan_xxxx
RAZORPAY_PRO_PLAN_ID=plan_xxxx

# === Integrations ===
SHOPIFY_API_KEY=xxxx
SHOPIFY_API_SECRET=xxxx

WOOCOMMERCE_CONSUMER_KEY=xxxx
WOOCOMMERCE_CONSUMER_SECRET=xxxx

META_APP_ID=xxxx
